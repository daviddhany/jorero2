<!doctype html><html lang="ar" dir="rtl"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title><%= typeof title !== 'undefined' ? title : 'Jorero' %></title><meta name="description" content="Jorero Online Shop - ملابس رجالي وحريمي وأطفالي"><link rel="icon" href="/public/images/logo.png"><link rel="stylesheet" href="/public/css/style.css"></head><body>
<div class="demos-redbar"><span>متنساش تعمل تسجيل دخول عشان هتكسب نقاط وخصومات أكتر كل ما تشتري من Jorero</span></div>
<header class="header demos-header">
