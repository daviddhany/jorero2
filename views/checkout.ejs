<%- include('partials/header') %>
<section class="page-head"><div><span class="eyebrow">Checkout</span><h1 data-i18n="checkout">إتمام الطلب</h1><p data-i18n="checkoutText">اكتب بياناتك وسيظهر الطلب للأدمن.</p></div></section>
<section class="checkout-page">
  <form class="checkout-form" method="post" action="/checkout">
    <% if(error){ %><div class="error"><%= error %></div><% } %>
    <label><span data-i18n="fullName">الاسم بالكامل</span><input name="customerName" required data-placeholder-ar="اسم العميل" data-placeholder-en="Customer name" placeholder="اسم العميل"></label>
    <label><span data-i18n="phoneNumber">رقم التليفون</span><input name="phone" required pattern="01[0-9]{9}" minlength="11" maxlength="11" inputmode="numeric" placeholder="01012345678" title="رقم التليفون لازم يكون 11 رقم ويبدأ بـ 01"></label>
    <label><span data-i18n="fullAddress">العنوان بالتفصيل</span><textarea name="address" required data-placeholder-ar="المحافظة، المنطقة، الشارع، رقم البيت، علامة مميزة" data-placeholder-en="City, area, street, building number, landmark" placeholder="المحافظة، المنطقة، الشارع، رقم البيت، علامة مميزة"></textarea></label>
    <label><span data-i18n="extraNotes">ملاحظات إضافية</span><textarea name="notes" data-placeholder-ar="اختياري" data-placeholder-en="Optional" placeholder="اختياري"></textarea></label>
    <button type="submit" class="btn big" data-i18n="confirmOrder">تأكيد الطلب</button>
  </form>
  <aside class="cart-summary"><h2 data-i18n="orderSummary">ملخص الطلب</h2><% items.forEach(item=>{ %><div class="summary-item"><p><b data-ar="<%= item.name %>" data-en="<%= item.nameEn || item.name %>"><%= item.name %></b></p><p><span data-i18n="size">المقاس</span>: <%= item.size || '-' %> | <span data-i18n="color">اللون</span>: <span data-ar="<%= item.color || '-' %>" data-en="<%= item.colorEn || item.color || '-' %>"><%= item.color || '-' %></span></p><p><span data-i18n="quantity">الكمية</span>: <%= item.quantity %> — <b><span class="money" data-price="<%= item.subtotal %>"><%= formatPrice(item.subtotal) %></span></b></p></div><% }) %><hr><p><span data-i18n="productsTotal">المنتجات</span>: <b><span class="money" data-price="<%= totals.itemsTotal %>"><%= formatPrice(totals.itemsTotal) %></span></b></p><p><span data-i18n="delivery">التوصيل</span>: <b><span class="money" data-price="<%= totals.deliveryPrice %>"><%= formatPrice(totals.deliveryPrice) %></span></b></p><h3><span data-i18n="total">الإجمالي</span>: <span class="money" data-price="<%= totals.total %>"><%= formatPrice(totals.total) %></span></h3></aside>
</section>
<%- include('partials/footer') %>
