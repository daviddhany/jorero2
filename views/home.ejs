<%- include('partials/header') %>
<% const heroImages = (settings.heroImages && settings.heroImages.length ? settings.heroImages : [settings.heroImage || (products[0] && products[0].images && products[0].images[0]) || '/public/images/logo.png']).filter(Boolean); %>

<section class="demos-hero" data-carousel>
  <% heroImages.forEach((img, index) => { %>
    <img class="hero-slide <%= index === 0 ? 'active' : '' %>" src="<%= img %>" alt="Jorero hero" onerror="this.onerror=null;this.src='/public/images/logo.png'">
  <% }) %>
  <div class="hero-overlay">
    <h1><%= settings.heroTitle || 'JORERO SUMMER' %></h1>
    <p><%= settings.heroSubtitle || 'أقوى تشكيلة ملابس عصرية في مكان واحد' %></p>
    <a class="btn big" href="/products">تسوق الآن</a>
  </div>
  <% if (heroImages.length > 1) { %><div class="hero-dots"><% heroImages.forEach((img, index) => { %><span class="<%= index === 0 ? 'active' : '' %>"></span><% }) %></div><% } %>
</section>

<section class="demos-intro">
  <h1>أقوى و أجدد تشكيلة ملابس<br>من Jorero</h1>
  <p>Jorero جايبلك أحدث الإطلالات في القمصان، السويت شيرت، الجواكيت والبناطيل في مكان واحد.</p>
</section>

<section class="demos-product-shell">
  <div class="grid demos-grid"><% products.slice(0,3).forEach(p=>{ %><%- include('partials/card',{p}) %><% }) %></div>
  <div class="slider-dots"><span></span><span class="active"></span><span></span></div>
</section>

<section class="demos-categories">
  <h2>اكتشف تشكيلتنا على<br>حسب اللي يناسبك</h2>
  <p>سواء بتدور على جاكيت للدريس، سويت شيرت خفيف، قميص شيك، أو بنطلون عملي... جمعنالك كل الفئات في مكان واحد عشان توصل للي يعجبك بسهولة.</p>
  <div class="category-mosaic">
    <a class="cat-tile tall" href="/products?category=قمصان"><h3>قمصان</h3><span>تشكيلة عصرية لجميع إطلالات القمصان</span><b>تسوق المزيد</b><img src="<%= (products[0] && products[0].images && products[0].images[0]) || '/public/images/logo.png' %>"></a>
    <div class="cat-stack">
      <a class="cat-tile" href="/products?category=جاكيت"><h3>جاكيت</h3><span>مجموعة الجواكيت الجديدة</span><b>تسوق المزيد</b><img src="<%= (products[1] && products[1].images && products[1].images[0]) || '/public/images/logo.png' %>"></a>
      <a class="cat-tile" href="/products?category=بناطيل"><h3>بناطيل</h3><span>راحة وأناقة يومية</span><b>تسوق المزيد</b><img src="<%= (products[2] && products[2].images && products[2].images[0]) || '/public/images/logo.png' %>"></a>
    </div>
    <a class="cat-tile tall" href="/products?category=سويت شيرت"><h3>سويت شيرت</h3><span>راحة وشياكة في نفس الوقت</span><b>تسوق المزيد</b><img src="<%= (products[3] && products[3].images && products[3].images[0]) || '/public/images/logo.png' %>"></a>
  </div>
</section>

<section id="new" class="demos-section-title"><h2>وصل حديثًا</h2><p>تشكيلة جديدة وصلت دلوقتي، موديلات عصرية وخامات مريحة تناسب ذوقك.</p></section>
<section class="demos-product-shell"><div class="grid demos-grid"><% products.filter(p=>p.newArrival).slice(0,3).forEach(p=>{ %><%- include('partials/card',{p}) %><% }) %></div><div class="slider-dots"><span></span><span class="active"></span><span></span></div></section>

<section class="demos-section-title"><h2>الحاجات من Jorero</h2></section>
<section class="demos-product-shell"><div class="grid demos-grid"><% products.slice(3,6).forEach(p=>{ %><%- include('partials/card',{p}) %><% }) %></div><div class="slider-dots"><span></span><span class="active"></span><span></span></div></section>

<section class="testimonials">
  <h2>آراء عملائنا في Jorero</h2>
  <div class="test-grid">
    <div><strong>★★★★★</strong><p>"الخامة ناعمة والمقاس مضبوط."</p><b>أحمد - المنتج: قميص</b></div>
    <div><strong>★★★★★</strong><p>"الطلب وصل بسرعة والتغليف محترم."</p><b>شريف - المنتج: سويت شيرت</b></div>
    <div><strong>★★★★★</strong><p>"الشكل أحسن من الصور والمقاس مظبوط."</p><b>كريم - المنتج: جاكيت</b></div>
  </div>
</section>

<%- include('partials/footer') %>
