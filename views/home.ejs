<%- include('partials/header') %>
<% const heroImages = (settings.heroImages && settings.heroImages.length ? settings.heroImages : [settings.heroImage || (products[0] && products[0].images && products[0].images[0]) || '/public/images/logo.png']).filter(Boolean); %>

<section class="demos-hero" data-carousel>
  <% heroImages.forEach((img, index) => { %>
    <img class="hero-slide <%= index === 0 ? 'active' : '' %>" src="<%= img %>" alt="Jorero hero" onerror="this.onerror=null;this.src='/public/images/logo.png'">
  <% }) %>
  <div class="hero-overlay">
    <h1><%= settings.heroTitle || 'JORERO SUMMER' %></h1>
    <p><%= settings.heroSubtitle || 'أقوى تشكيلة ملابس عصرية في مكان واحد' %></p>
    <a class="btn big" href="/products">تسوق الآن</a>
  </div>
  <% if (heroImages.length > 1) { %>
    <button class="hero-arrow hero-prev" type="button" data-carousel-prev>‹</button>
    <button class="hero-arrow hero-next" type="button" data-carousel-next>›</button>
    <div class="hero-dots"><% heroImages.forEach((img, index) => { %><span class="<%= index === 0 ? 'active' : '' %>" data-carousel-dot="<%= index %>"></span><% }) %></div>
  <% } %>
</section>

<section class="demos-intro">
  <h1>أقوى و أجدد تشكيلة ملابس<br>من Jorero</h1>
  <p>Jorero جايبلك أحدث الإطلالات في القمصان، السويت شيرت، الجواكيت والبناطيل في مكان واحد.</p>
</section>

<section class="demos-product-shell" data-product-slider>
  <button class="product-arrow product-prev" type="button" data-product-prev>‹</button>
  <div class="product-scroll demos-grid"><% products.slice(0,6).forEach(p=>{ %><%- include('partials/card',{p}) %><% }) %></div>
  <button class="product-arrow product-next" type="button" data-product-next>›</button>
  <div class="slider-dots"><% products.slice(0,6).forEach((p,i)=>{ %><span class="<%= i===0?'active':'' %>"></span><% }) %></div>
</section>

<section class="demos-categories">
  <h2>اكتشف تشكيلتنا على<br>حسب اللي يناسبك</h2>
  <p>سواء بتدور على جاكيت، سويت شيرت، قميص، أو بنطلون عملي... جمعنالك كل الفئات في مكان واحد عشان توصل للي يعجبك بسهولة.</p>
  <% const productCategoriesForTiles = [...new Set(products.map(p => p.category).filter(Boolean))]; const visibleCategories = (settings.categoryOptions && settings.categoryOptions.length ? settings.categoryOptions : productCategoriesForTiles).slice(0,4); %>
  <div class="category-mosaic">
    <% visibleCategories.forEach((catName, index) => { const catProduct = products.find(p => p.category === catName) || products[index] || products[0]; const catImg = (catProduct && catProduct.images && catProduct.images[0]) || '/public/images/logo.png'; %>
      <% if (index === 1) { %><div class="cat-stack"><% } %>
      <a class="cat-tile <%= (index === 0 || index === 3) ? 'tall' : '' %>" href="/products?category=<%= encodeURIComponent(catName) %>">
        <h3><%= catName %></h3><span>تشكيلة مختارة من <%= catName %></span><b>تسوق المزيد</b><img src="<%= catImg %>" onerror="this.onerror=null;this.src='/public/images/logo.png'">
      </a>
      <% if (index === 2) { %></div><% } %>
    <% }) %>
  </div>
</section>

<section id="new" class="demos-section-title"><h2>وصل حديثًا</h2><p>تشكيلة جديدة وصلت دلوقتي، موديلات عصرية وخامات مريحة تناسب ذوقك.</p></section>
<% const newProducts = products.filter(p=>p.newArrival); %>
<% if (newProducts.length) { %>
<section class="demos-product-shell" data-product-slider>
  <button class="product-arrow product-prev" type="button" data-product-prev>‹</button>
  <div class="product-scroll demos-grid"><% newProducts.forEach(p=>{ %><%- include('partials/card',{p}) %><% }) %></div>
  <button class="product-arrow product-next" type="button" data-product-next>›</button>
  <div class="slider-dots"><% newProducts.forEach((p,i)=>{ %><span class="<%= i===0?'active':'' %>"></span><% }) %></div>
</section>
<% } %>

<% const groupedProducts = {}; products.forEach(p => { const c = p.category || 'منتجات أخرى'; if (!groupedProducts[c]) groupedProducts[c] = []; groupedProducts[c].push(p); }); %>
<% Object.keys(groupedProducts).forEach(categoryName => { const list = groupedProducts[categoryName]; %>
  <section class="demos-section-title"><h2><%= categoryName %></h2></section>
  <section class="demos-product-shell" data-product-slider>
    <button class="product-arrow product-prev" type="button" data-product-prev>‹</button>
    <div class="product-scroll demos-grid"><% list.forEach(p=>{ %><%- include('partials/card',{p}) %><% }) %></div>
    <button class="product-arrow product-next" type="button" data-product-next>›</button>
    <div class="slider-dots"><% list.forEach((p,i)=>{ %><span class="<%= i===0?'active':'' %>"></span><% }) %></div>
  </section>
<% }) %>

<section class="testimonials">
  <h2>آراء عملائنا في Jorero</h2>
  <div class="test-grid">
    <div><strong>★★★★★</strong><p>"الخامة ناعمة والمقاس مضبوط."</p><b>أحمد - المنتج: قميص</b></div>
    <div><strong>★★★★★</strong><p>"الطلب وصل بسرعة والتغليف محترم."</p><b>شريف - المنتج: سويت شيرت</b></div>
    <div><strong>★★★★★</strong><p>"الشكل أحسن من الصور والمقاس مظبوط."</p><b>كريم - المنتج: جاكيت</b></div>
  </div>
</section>

<%- include('partials/footer') %>
