<!doctype html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title><%= title %></title>
  <link rel="stylesheet" href="/public/css/style.css">
</head>
<body>
<div class="admin-layout">
  <%- include('_side') %>

  <main class="admin-main">
    <h1>إعدادات Jorero</h1>
    <form class="product-form" method="post" enctype="multipart/form-data" action="/marly-dashboard/settings">
      <label>النص الصغير أعلى الهيرو
        <input name="heroEyebrow" value="<%= settings.heroEyebrow || '' %>">
      </label>
      <label>عنوان الهيرو الرئيسي
        <input name="heroTitle" value="<%= settings.heroTitle || '' %>">
      </label>
      <label class="full">وصف الهيرو
        <textarea name="heroSubtitle"><%= settings.heroSubtitle || '' %></textarea>
      </label>
      <label>نص زر التسوق
        <input name="heroPrimaryText" value="<%= settings.heroPrimaryText || 'تسوق الآن' %>">
      </label>
      <label>سعر التوصيل
        <input type="number" name="deliveryPrice" value="<%= settings.deliveryPrice || 0 %>">
      </label>
      <label>عنوان ملاحظة المعرض
        <input name="homeNoteTitle" value="<%= settings.homeNoteTitle || '' %>">
      </label>
      <label class="full">نص ملاحظة المعرض
        <input name="homeNoteText" value="<%= settings.homeNoteText || '' %>">
      </label>

      <label class="full">المقاسات العامة في صفحة إضافة المنتج
        <textarea name="defaultSizes" placeholder="اكتب كل المقاسات وبينهم فاصلة. مثال: 2, 4, 6, 8, S, M, L"><%= (settings.defaultSizes && settings.defaultSizes.length ? settings.defaultSizes : ['2','4','6','8','S','M','L','XL','XXL','3XL','4XL']).join(', ') %></textarea>
      </label>

      <label class="full">صور الهيرو Carousel - يمكنك رفع أكثر من صورة
        <input type="file" name="heroImageFiles" multiple accept="image/*">
      </label>

      <% const heroImages = (settings.heroImages && settings.heroImages.length ? settings.heroImages : [settings.heroImage]).filter(Boolean); %>
      <% if (heroImages.length) { %>
        <div class="full admin-images-block">
          <h3>صور الهيرو الحالية</h3>
          <p>علّم على الصورة اللي عايز تمسحها ثم اضغط حفظ الإعدادات.</p>
          <div class="admin-photo-grid">
            <% heroImages.forEach(img => { %>
              <label class="admin-photo-item">
                <img src="<%= img %>" alt="صورة الهيرو" onerror="this.onerror=null;this.src='/public/images/logo.png'">
                <span><input type="checkbox" name="removeHeroImages" value="<%= img %>"> حذف الصورة</span>
              </label>
            <% }) %>
          </div>
        </div>
      <% } %>

      <button class="btn big">حفظ الإعدادات</button>
    </form>
  </main>
</div>
</body>
</html>
