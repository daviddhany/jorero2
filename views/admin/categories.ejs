<!doctype html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title><%= title %></title>
  <link rel="stylesheet" href="/public/css/style.css">
</head>
<body>
<div class="admin-layout">
  <%- include('_side') %>
  <main class="admin-main">
    <div class="admin-head">
      <h1>إدارة الفئات</h1>
      <a class="btn light" href="/marly-dashboard/products/new">+ إضافة منتج</a>
    </div>

    <form class="product-form category-admin-form" method="post" action="/marly-dashboard/categories">
      <label>اسم الفئة عربي
        <input name="category" required placeholder="مثال: قمصان، بناطيل، جاكيت">
      </label>
      <label>Category English
        <input name="categoryEn" required placeholder="Example: Shirts, Pants, Jackets">
      </label>
      <button type="submit" class="btn big">+ إضافة فئة</button>
    </form>

    <table>
      <thead>
        <tr><th>الفئة عربي</th><th>Category English</th><th>عدد المنتجات</th><th>تحكم</th></tr>
      </thead>
      <tbody>
        <% const cats = settings.categoryOptions && settings.categoryOptions.length ? settings.categoryOptions : []; const catsEn = settings.categoryOptionsEn && settings.categoryOptionsEn.length ? settings.categoryOptionsEn : cats; %>
        <% cats.forEach((c,i) => { %>
          <tr>
            <td><%= c %></td>
            <td><%= catsEn[i] || c %></td>
            <td><%= counts[c] || 0 %></td>
            <td>
              <form class="inline" method="post" action="/marly-dashboard/categories?_method=DELETE" onsubmit="return confirm('لو مسحت الفئة، أي منتج فيها هيتحول إلى منتجات أخرى. متأكد؟')">
                <input type="hidden" name="category" value="<%= c %>">
                <button type="submit" class="danger">حذف</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
    <p class="muted-note">عند حذف فئة، المنتجات الموجودة فيها لا تتحذف؛ تتحول تلقائيًا إلى "منتجات أخرى".</p>
  </main>
</div>
</body>
</html>
