<!doctype html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title><%= title %></title>
  <link rel="stylesheet" href="/public/css/style.css">
</head>
<body>
<div class="admin-layout">
  <%- include('_side') %>
  <main class="admin-main">
    <div class="admin-head">
      <h1>إدارة الفئات</h1>
      <a class="btn light" href="/marly-dashboard/products/new">+ إضافة منتج</a>
    </div>

    <form class="product-form category-admin-form" method="post" action="/marly-dashboard/categories">
      <label class="full">اسم الفئة الجديدة
        <input name="category" required placeholder="مثال: قمصان، بناطيل، جاكيت">
      </label>
      <button class="btn big">+ إضافة فئة</button>
    </form>

    <table>
      <thead>
        <tr><th>الفئة</th><th>عدد المنتجات</th><th>تحكم</th></tr>
      </thead>
      <tbody>
        <% const cats = settings.categoryOptions && settings.categoryOptions.length ? settings.categoryOptions : []; %>
        <% cats.forEach(c => { %>
          <tr>
            <td><%= c %></td>
            <td><%= counts[c] || 0 %></td>
            <td>
              <form class="inline" method="post" action="/marly-dashboard/categories?_method=DELETE" onsubmit="return confirm('لو مسحت الفئة، أي منتج فيها هيتحول إلى منتجات أخرى. متأكد؟')">
                <input type="hidden" name="category" value="<%= c %>">
                <button class="danger">حذف</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
    <p class="muted-note">عند حذف فئة، المنتجات الموجودة فيها لا تتحذف؛ تتحول تلقائيًا إلى "منتجات أخرى".</p>
  </main>
</div>
</body>
</html>
