<!doctype html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title><%= title %></title>
  <link rel="stylesheet" href="/public/css/style.css">
</head>
<body>
<div class="admin-layout">
  <%- include('_side') %>
  <main class="admin-main">
    <div class="admin-head"><h1>طلبات العملاء</h1></div>
    <div class="order-tabs">
      <a class="btn <%= status === 'active' ? '' : 'light' %>" href="/marly-dashboard/orders">الحالية</a>
      <% ['pending','processing','shipped','done','cancelled'].forEach(s => { %>
        <a class="btn <%= status === s ? '' : 'light' %>" href="/marly-dashboard/orders?status=<%= s %>"><%= STATUS_LABELS[s] %></a>
      <% }) %>
    </div>
    <% if(!orders.length){ %><div class="empty">لا توجد طلبات في هذا القسم.</div><% } %>
    <div class="orders-list">
      <% orders.forEach(order=>{ %>
        <div class="order-card">
          <div class="order-head"><h3>طلب: <%= order._id %></h3><b><%= formatPrice(order.total) %></b></div>
          <p><b>الحالة:</b> <%= STATUS_LABELS[order.status] || order.status %></p>
          <p><b>العميل:</b> <%= order.customerName %> | <b>الموبايل:</b> <%= order.phone %></p>
          <p><b>العنوان:</b> <%= order.address %></p>
          <p><b>ملاحظات:</b> <%= order.notes || '-' %></p>
          <table><thead><tr><th>الصورة</th><th>المنتج</th><th>مقاس</th><th>لون</th><th>كمية</th><th>الإجمالي</th></tr></thead><tbody>
            <% order.items.forEach(item=>{ %>
              <tr><td><img class="mini" src="<%= item.image %>" onerror="this.onerror=null;this.src='/public/images/logo.png'"></td><td><%= item.name %></td><td><%= item.size || '-' %></td><td><%= item.color || '-' %></td><td><%= item.quantity %></td><td><%= formatPrice(item.subtotal) %></td></tr>
            <% }) %>
          </tbody></table>
          <p>المنتجات: <%= formatPrice(order.itemsTotal) %> | التوصيل: <%= formatPrice(order.deliveryPrice) %></p>
          <form class="status-form" method="post" action="/marly-dashboard/orders/<%= order._id %>/status">
            <input type="hidden" name="backStatus" value="<%= status %>">
            <select name="status">
              <% ['pending','processing','shipped','done','cancelled'].forEach(s => { %>
                <option value="<%= s %>" <%= order.status === s ? 'selected' : '' %>><%= STATUS_LABELS[s] %></option>
              <% }) %>
            </select>
            <label class="mini-check"><input type="checkbox" name="notifyCustomer" checked> إرسال واتساب للعميل</label>
            <button class="btn">تحديث الحالة</button>
          </form>
        </div>
      <% }) %>
    </div>
  </main>
</div>
</body>
</html>
