<%- include('partials/header') %>
<section class="page-head"><div><span class="eyebrow" data-i18n="cart">السلة</span><h1 data-i18n="yourOrders">طلباتك</h1><p data-i18n="reviewBeforeCheckout">راجع المنتجات قبل إتمام الطلب.</p></div></section>
<section class="cart-page">
  <% if(!items.length){ %><div class="empty"><h2 data-i18n="emptyCart">السلة فاضية</h2><a class="btn" href="/products" data-i18n="shopNow">تسوق الآن</a></div><% } else { %>
    <div class="cart-list"><% items.forEach((item,index)=>{ %><div class="cart-item"><img src="<%= item.image %>" onerror="this.onerror=null;this.src='/public/images/logo.png'"><div><h3 data-ar="<%= item.name %>" data-en="<%= item.nameEn || item.name %>"><%= item.name %></h3><p><span data-i18n="size">المقاس</span>: <%= item.size || '-' %> | <span data-i18n="color">اللون</span>: <%= item.color || '-' %></p><p><%= item.quantity %> × <%= formatPrice(item.price) %></p></div><b><%= formatPrice(item.subtotal) %></b><form method="post" action="/cart/remove/<%= index %>"><button class="danger" data-i18n="delete">حذف</button></form></div><% }) %></div>
    <div class="cart-summary"><h2 data-i18n="total">الإجمالي</h2><p><span data-i18n="productsTotal">المنتجات</span>: <b><%= formatPrice(totals.itemsTotal) %></b></p><p><span data-i18n="delivery">التوصيل</span>: <b><%= formatPrice(totals.deliveryPrice) %></b></p><h3><span data-i18n="finalTotal">الإجمالي النهائي</span>: <%= formatPrice(totals.total) %></h3><a class="btn big" href="/checkout" data-i18n="checkout">إتمام الطلب</a></div>
  <% } %>
</section>
<%- include('partials/footer') %>
